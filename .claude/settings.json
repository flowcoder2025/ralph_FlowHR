{
  "permissions": {
    "allow": [
      "Write",
      "Edit"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/protect-requirements.sh",
            "timeout": 10,
            "statusMessage": "요구사항 보호 검사 중..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/enforce-delegate-mode.sh",
            "timeout": 5,
            "statusMessage": "Delegate mode 검사 중..."
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/enforce-plan-approval.sh",
            "timeout": 5,
            "statusMessage": "Plan approval 검사 중..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/verify-on-commit.sh",
            "timeout": 30,
            "statusMessage": "커밋 전 검증 중..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/verify-task-completion.sh",
            "timeout": 120,
            "statusMessage": "태스크 완료 검증 중..."
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/verify-teammate-idle.sh",
            "timeout": 60,
            "statusMessage": "팀원 품질 게이트 확인 중..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/update-knowledge-on-stop.sh",
            "timeout": 10,
            "statusMessage": "Knowledge 동기화 확인 중..."
          }
        ]
      }
    ]
  }
}
