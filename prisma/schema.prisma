generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────

enum TenantPlan {
  TRIAL
  STARTER
  GROWTH
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DISABLED
  PENDING
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  PENDING_RESIGNATION
  RESIGNED
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum EmployeeChangeType {
  HIRE
  TRANSFER
  PROMOTION
  RESIGNATION
  TERMINATION
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EARLY_LEAVE
  HALF_DAY
}

enum ShiftType {
  REGULAR
  MORNING
  AFTERNOON
  NIGHT
  FLEXIBLE
}

enum ExceptionType {
  CORRECTION
  OVERTIME
  BUSINESS_TRIP
  REMOTE_WORK
}

enum ExceptionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClosingStatus {
  OPEN
  IN_REVIEW
  CLOSED
}

enum LeaveType {
  ANNUAL
  HALF_DAY
  SICK
  FAMILY_EVENT
  COMPENSATORY
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WorkflowStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

enum ApprovalRequestStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
  ESCALATED
}

enum DocumentStatus {
  DRAFT
  SENT
  VIEWED
  SIGNED
  EXPIRED
  CANCELLED
}

enum DocumentTemplateCategory {
  CONTRACT
  NOTICE
  NDA
  CERTIFICATE
}

enum RequestPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum PayrollRuleType {
  FIXED
  VARIABLE
  DEDUCTION
}

enum PayrollRunStatus {
  DRAFT
  DATA_COLLECTION
  CHANGE_REVIEW
  CALCULATION
  REVIEW
  CONFIRMED
  CANCELLED
}

enum PayslipStatus {
  DRAFT
  CONFIRMED
  SENT
  REISSUE_REQUESTED
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EvalCycleStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum EvalCycleType {
  HALF_YEARLY
  QUARTERLY
  ANNUAL
}

enum EvaluationStatus {
  NOT_STARTED
  SELF_REVIEW
  PEER_REVIEW
  MANAGER_REVIEW
  COMPLETED
}

enum OneOnOneStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum JobPostingStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  FIRST_INTERVIEW
  SECOND_INTERVIEW
  FINAL
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum BoardingTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum BillingAccountStatus {
  ACTIVE
  FAILED
  GRACE_PERIOD
  SUSPENDED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  CANCELLED
  GRACE
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum SupportTicketCategory {
  BUG
  FEATURE_REQUEST
  QUESTION
  MIGRATION
  SECURITY
  BILLING
}

enum NotificationType {
  SYSTEM
  ATTENDANCE
  LEAVE
  DOCUMENT
  PAYROLL
  APPROVAL
}

enum PlatformAuditAction {
  LOGIN
  LOGOUT
  TENANT_CREATE
  TENANT_UPDATE
  TENANT_SUSPEND
  PLAN_CHANGE
  SETTING_CHANGE
  SECURITY_EVENT
  SUPPORT_ACTION
}

enum PlatformAuditResult {
  SUCCESS
  FAILURE
}

enum WageType {
  COMPREHENSIVE
  STANDARD
  HOURLY
  DAILY
  ANNUAL
}

enum ContractStatus {
  DRAFT
  PENDING_SIGN
  SIGNED
  EXPIRED
  TERMINATED
}

enum SubsidyStatus {
  ELIGIBLE
  APPLIED
  APPROVED
  REJECTED
  RECEIVING
  COMPLETED
  EXPIRED
}

enum SeveranceStatus {
  ESTIMATED
  CONFIRMED
  PAID
}

// ─── Tenant ───────────────────────────────────────────────

model Tenant {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  plan      TenantPlan   @default(TRIAL)
  status    TenantStatus @default(ACTIVE)
  settings  Json         @default("{}")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users           User[]
  roles           Role[]
  departments     Department[]
  positions       Position[]
  employees       Employee[]
  employeeChanges EmployeeChange[]
  shifts               Shift[]
  shiftAssignments     ShiftAssignment[]
  attendanceRecords    AttendanceRecord[]
  attendanceExceptions AttendanceException[]
  attendanceClosings   AttendanceClosing[]
  leavePolicies        LeavePolicy[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  workflows            Workflow[]
  approvalRequests     ApprovalRequest[]
  approvalSteps        ApprovalStep[]
  documentTemplates    DocumentTemplate[]
  documents            Document[]
  signatures           Signature[]
  payrollRules         PayrollRule[]
  payrollRuns          PayrollRun[]
  payslips             Payslip[]
  goals                Goal[]
  evalCycles           EvalCycle[]
  evaluations          Evaluation[]
  oneOnOnes            OneOnOne[]
  jobPostings          JobPosting[]
  applications         Application[]
  onboardingTasks      OnboardingTask[]
  offboardingTasks     OffboardingTask[]
  billingAccounts      BillingAccount[]
  invoices             Invoice[]
  supportTickets       SupportTicket[]
  platformAuditLogs    PlatformAuditLog[]
  notifications        Notification[]
  salaryHistories      SalaryHistory[]
  insuranceRateConfigs   InsuranceRateConfig[]
  insuranceContributions InsuranceContribution[]
  wageConfigs              WageConfig[]
  severanceCalculations    SeveranceCalculation[]
  employmentContracts      EmploymentContract[]
  subsidyPrograms          SubsidyProgram[]
  subsidyMatches           SubsidyMatch[]
}

// ─── Role ─────────────────────────────────────────────────

model Role {
  id          String  @id @default(cuid())
  tenantId    String?
  name        String
  description String?
  permissions Json    @default("[]")
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, name])
}

// ─── User (NextAuth compatible) ───────────────────────────

model User {
  id            String     @id @default(cuid())
  tenantId      String?
  roleId        String?
  email         String     @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  status        UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role     Role?     @relation(fields: [roleId], references: [id])
  accounts Account[]
  sessions Session[]
  employee Employee?
}

// ─── Account (NextAuth compatible) ────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─── Session (NextAuth compatible) ────────────────────────

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── VerificationToken (NextAuth compatible) ──────────────

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Department ─────────────────────────────────────────────

model Department {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  description String?
  parentId    String?
  managerId   String?
  sortOrder   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Department? @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")
  manager  Employee?   @relation("DepartmentManager", fields: [managerId], references: [id])

  employees          Employee[]
  changesFrom        EmployeeChange[] @relation("ChangeFromDept")
  changesTo          EmployeeChange[] @relation("ChangeToDept")

  @@unique([tenantId, code])
}

// ─── Position ───────────────────────────────────────────────

model Position {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  level       Int     @default(1)
  description String?
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]
  changesFrom EmployeeChange[] @relation("ChangeFromPos")
  changesTo   EmployeeChange[] @relation("ChangeToPos")

  @@unique([tenantId, name])
}

// ─── Employee ───────────────────────────────────────────────

model Employee {
  id             String          @id @default(cuid())
  tenantId       String
  userId         String?         @unique
  departmentId   String?
  positionId     String?
  employeeNumber String
  name           String
  email          String
  phone          String?
  hireDate       DateTime
  resignDate     DateTime?
  status         EmployeeStatus  @default(ACTIVE)
  type           EmploymentType  @default(FULL_TIME)
  birthDate        DateTime?
  gender           String?
  disabilityStatus Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  position   Position?   @relation(fields: [positionId], references: [id])

  changes            EmployeeChange[]
  managedDepartments Department[]     @relation("DepartmentManager")
  shiftAssignments     ShiftAssignment[]
  attendanceRecords    AttendanceRecord[]
  attendanceExceptions AttendanceException[]
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  approvalRequests       ApprovalRequest[] @relation("ApprovalRequester")
  approvalStepsAssigned  ApprovalStep[]    @relation("ApprovalStepApprover")
  sentDocuments          Document[]        @relation("DocumentSender")
  receivedDocuments      Document[]        @relation("DocumentRecipient")
  signatures             Signature[]
  payslips               Payslip[]
  goals                  Goal[]
  evaluations            Evaluation[]
  oneOnOnesAsManager     OneOnOne[]        @relation("OneOnOneManager")
  oneOnOnesAsEmployee    OneOnOne[]        @relation("OneOnOneEmployee")
  jobPostings            JobPosting[]
  applications           Application[]
  onboardingTasks        OnboardingTask[]
  offboardingTasks       OffboardingTask[]
  notifications          Notification[]
  salaryHistories        SalaryHistory[]
  insuranceContributions InsuranceContribution[]
  wageConfig             WageConfig?
  severanceCalculations  SeveranceCalculation[]
  employmentContracts    EmploymentContract[]
  subsidyMatches         SubsidyMatch[]

  @@unique([tenantId, employeeNumber])
}

// ─── EmployeeChange ─────────────────────────────────────────

model EmployeeChange {
  id               String             @id @default(cuid())
  tenantId         String
  employeeId       String
  type             EmployeeChangeType
  description      String?
  fromDepartmentId String?
  toDepartmentId   String?
  fromPositionId   String?
  toPositionId     String?
  effectiveDate    DateTime

  createdAt DateTime @default(now())

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee       Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fromDepartment Department? @relation("ChangeFromDept", fields: [fromDepartmentId], references: [id])
  toDepartment   Department? @relation("ChangeToDept", fields: [toDepartmentId], references: [id])
  fromPosition   Position?   @relation("ChangeFromPos", fields: [fromPositionId], references: [id])
  toPosition     Position?   @relation("ChangeToPos", fields: [toPositionId], references: [id])
}

// ─── Shift ─────────────────────────────────────────────────

model Shift {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  type        ShiftType @default(REGULAR)
  startTime   String    // "HH:mm" format
  endTime     String    // "HH:mm" format
  breakMinutes Int      @default(60)
  color       String    @default("#3B82F6")
  isActive    Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments ShiftAssignment[]

  @@unique([tenantId, name])
}

// ─── ShiftAssignment ───────────────────────────────────────

model ShiftAssignment {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String
  shiftId    String
  startDate  DateTime
  endDate    DateTime?

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

// ─── AttendanceRecord ──────────────────────────────────────

model AttendanceRecord {
  id              String           @id @default(cuid())
  tenantId        String
  employeeId      String
  date            DateTime
  status          AttendanceStatus @default(PRESENT)
  checkIn         DateTime?
  checkOut        DateTime?
  workMinutes     Int?
  overtime        Int              @default(0)
  note            String?
  checkInLat      Float?
  checkInLon      Float?
  checkOutLat     Float?
  checkOutLon     Float?
  checkInGpsStatus  String?        // "IN_OFFICE" | "OUT_OF_OFFICE" | "NO_GPS"
  checkOutGpsStatus String?        // "IN_OFFICE" | "OUT_OF_OFFICE" | "NO_GPS"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
}

// ─── AttendanceException ───────────────────────────────────

model AttendanceException {
  id                String          @id @default(cuid())
  tenantId          String
  employeeId        String
  type              ExceptionType
  status            ExceptionStatus @default(PENDING)
  date              DateTime
  reason            String
  approvedBy        String?
  approvedAt        DateTime?
  correctedCheckIn  String?         // 정정 요청 출근 시간 (HH:mm)
  correctedCheckOut String?         // 정정 요청 퇴근 시간 (HH:mm)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── AttendanceClosing ─────────────────────────────────────

model AttendanceClosing {
  id         String        @id @default(cuid())
  tenantId   String
  year       Int
  month      Int
  status     ClosingStatus @default(OPEN)
  closedBy   String?
  closedAt   DateTime?
  totalDays  Int           @default(0)
  totalHours Float         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, year, month])
}

// ─── LeavePolicy ─────────────────────────────────────────

model LeavePolicy {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  type            LeaveType
  description     String?
  defaultDays     Float
  carryOverLimit  Float     @default(0)
  requiresApproval Boolean  @default(true)
  isActive        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@unique([tenantId, type])
}

// ─── LeaveBalance ────────────────────────────────────────

model LeaveBalance {
  id           String @id @default(cuid())
  tenantId     String
  employeeId   String
  policyId     String
  year         Int
  totalDays    Float
  usedDays     Float  @default(0)
  pendingDays  Float  @default(0)
  carriedOver  Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, policyId, year])
}

// ─── LeaveRequest ────────────────────────────────────────

model LeaveRequest {
  id          String             @id @default(cuid())
  tenantId    String
  employeeId  String
  policyId    String
  status      LeaveRequestStatus @default(PENDING)
  startDate   DateTime
  endDate     DateTime
  days        Float
  reason      String?
  approvedBy  String?
  approvedAt  DateTime?
  rejectedBy  String?
  rejectedAt  DateTime?
  rejectReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy   LeavePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
}

// ─── Workflow ──────────────────────────────────────────────

model Workflow {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  description String?
  triggerType String
  status      WorkflowStatus @default(ACTIVE)
  steps       Json           @default("[]")
  conditions  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvalRequests ApprovalRequest[]

  @@unique([tenantId, name])
}

// ─── ApprovalRequest ──────────────────────────────────────

model ApprovalRequest {
  id          String                @id @default(cuid())
  tenantId    String
  workflowId  String
  requesterId String
  title       String
  description String?
  status      ApprovalRequestStatus @default(PENDING)
  priority    RequestPriority       @default(MEDIUM)
  requestType String
  data        Json?
  escalatedAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow  Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  requester Employee       @relation("ApprovalRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  steps     ApprovalStep[]
}

// ─── ApprovalStep ─────────────────────────────────────────

model ApprovalStep {
  id        String                @id @default(cuid())
  tenantId  String
  requestId String
  stepOrder Int
  approverId String
  status    ApprovalRequestStatus @default(PENDING)
  comment   String?
  actionAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request  ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver Employee        @relation("ApprovalStepApprover", fields: [approverId], references: [id], onDelete: Cascade)
}

// ─── DocumentTemplate ───────────────────────────────────

model DocumentTemplate {
  id          String                   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  category    DocumentTemplateCategory
  content     Json                     @default("{}")
  version     String                   @default("1.0")
  usageCount  Int                      @default(0)
  isActive    Boolean                  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents Document[]

  @@unique([tenantId, name])
}

// ─── Document ───────────────────────────────────────────

model Document {
  id          String         @id @default(cuid())
  tenantId    String
  templateId  String
  senderId    String
  recipientId String
  title       String
  status      DocumentStatus @default(DRAFT)
  deadline    DateTime?
  sentAt      DateTime?
  viewedAt    DateTime?
  completedAt DateTime?
  memo        String?
  notifyEmail Boolean        @default(true)
  notifyReminder Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template  DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  sender    Employee         @relation("DocumentSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient Employee         @relation("DocumentRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  signatures Signature[]
}

// ─── Signature ──────────────────────────────────────────

model Signature {
  id            String  @id @default(cuid())
  tenantId      String
  documentId    String
  signerId      String
  signatureData String  @db.Text
  ipAddress     String?
  signedAt      DateTime @default(now())

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signer   Employee @relation(fields: [signerId], references: [id], onDelete: Cascade)

  @@unique([documentId, signerId])
}

// ─── PayrollRule ───────────────────────────────────────

model PayrollRule {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  type        PayrollRuleType
  description String?
  formula     String
  rate        Float?
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

// ─── PayrollRun ───────────────────────────────────────

model PayrollRun {
  id              String           @id @default(cuid())
  tenantId        String
  year            Int
  month           Int
  status          PayrollRunStatus @default(DRAFT)
  currentStep     Int              @default(1)
  totalEmployees  Int              @default(0)
  totalAmount     Float            @default(0)
  confirmedBy     String?
  confirmedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payslips Payslip[]

  @@unique([tenantId, year, month])
}

// ─── Payslip ──────────────────────────────────────────

model Payslip {
  id            String        @id @default(cuid())
  tenantId      String
  payrollRunId  String
  employeeId    String
  baseSalary    Float
  allowances    Float         @default(0)
  deductions    Float         @default(0)
  netAmount     Float
  breakdown     Json          @default("{}")
  status        PayslipStatus @default(DRAFT)
  sentAt        DateTime?
  viewedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
}

// ─── Goal ────────────────────────────────────────────

model Goal {
  id          String     @id @default(cuid())
  tenantId    String
  employeeId  String
  cycleId     String
  title       String
  description String?
  progress    Int        @default(0) // 0-100
  status      GoalStatus @default(NOT_STARTED)
  weight      Float      @default(1.0)
  dueDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle    EvalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
}

// ─── EvalCycle ───────────────────────────────────────

model EvalCycle {
  id        String          @id @default(cuid())
  tenantId  String
  name      String
  startDate DateTime
  endDate   DateTime
  type      EvalCycleType   @default(HALF_YEARLY)
  status    EvalCycleStatus @default(DRAFT)
  weights   Json            @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  goals       Goal[]
  evaluations Evaluation[]

  @@unique([tenantId, name])
}

// ─── Evaluation ──────────────────────────────────────

model Evaluation {
  id            String           @id @default(cuid())
  tenantId      String
  employeeId    String
  cycleId       String
  status        EvaluationStatus @default(NOT_STARTED)
  selfScore     Float?
  peerScore     Float?
  managerScore  Float?
  finalScore    Float?
  selfComment   String?
  managerComment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  cycle    EvalCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, cycleId])
}

// ─── OneOnOne ────────────────────────────────────────

model OneOnOne {
  id          String         @id @default(cuid())
  tenantId    String
  managerId   String
  employeeId  String
  scheduledAt DateTime
  duration    Int            @default(30) // minutes
  status      OneOnOneStatus @default(SCHEDULED)
  agenda      String?
  notes       String?        @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager  Employee @relation("OneOnOneManager", fields: [managerId], references: [id], onDelete: Cascade)
  employee Employee @relation("OneOnOneEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── JobPosting ──────────────────────────────────────

model JobPosting {
  id           String           @id @default(cuid())
  tenantId     String
  title        String
  departmentId String?
  positionId   String?
  hiringManagerId String
  status       JobPostingStatus @default(DRAFT)
  description  String?          @db.Text
  requirements String?          @db.Text
  location     String?
  employmentType EmploymentType @default(FULL_TIME)
  headcount    Int              @default(1)
  openDate     DateTime?
  closeDate    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hiringManager Employee      @relation(fields: [hiringManagerId], references: [id], onDelete: Cascade)
  applications  Application[]

  @@unique([tenantId, title])
}

// ─── Application ─────────────────────────────────────

model Application {
  id            String            @id @default(cuid())
  tenantId      String
  jobPostingId  String
  candidateName String
  candidateEmail String
  candidatePhone String?
  resumeUrl     String?
  status        ApplicationStatus @default(APPLIED)
  stage         Int               @default(1) // pipeline stage order
  rating        Int?              // 1-5
  notes         String?           @db.Text
  appliedAt     DateTime          @default(now())
  hiredAt       DateTime?
  rejectedAt    DateTime?
  assigneeId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  assignee   Employee?  @relation(fields: [assigneeId], references: [id])
}

// ─── OnboardingTask ──────────────────────────────────

model OnboardingTask {
  id          String             @id @default(cuid())
  tenantId    String
  employeeId  String
  title       String
  description String?
  category    String             // e.g. "IT", "HR", "ADMIN", "TEAM"
  status      BoardingTaskStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── OffboardingTask ─────────────────────────────────

model OffboardingTask {
  id          String             @id @default(cuid())
  tenantId    String
  employeeId  String
  title       String
  description String?
  category    String             // e.g. "IT", "HR", "ADMIN", "FINANCE", "LEGAL", "TEAM"
  status      BoardingTaskStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── Plan ──────────────────────────────────────────────

model Plan {
  id               String     @id @default(cuid())
  name             String     @unique
  description      String?
  pricePerSeat     Int        // 월 요금 (원 단위)
  maxSeats         Int?       // null = 무제한
  storageGb        Int        @default(10)
  apiCallsPerMonth Int        @default(50000)
  supportLevel     String     @default("email") // "email", "email_chat", "dedicated"
  features         Json       @default("[]")
  isActive         Boolean    @default(true)
  sortOrder        Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  billingAccounts BillingAccount[]
}

// ─── BillingAccount ────────────────────────────────────

model BillingAccount {
  id             String               @id @default(cuid())
  tenantId       String
  planId         String
  paymentMethod  String               // e.g. "법인카드 ****-4523", "계좌이체"
  nextBillingDate DateTime
  monthlyAmount  Float                @default(0)
  status         BillingAccountStatus @default(ACTIVE)
  billingEmail   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@unique([tenantId])
}

// ─── Invoice ───────────────────────────────────────────

model Invoice {
  id               String        @id @default(cuid())
  tenantId         String
  billingAccountId String
  invoiceNumber    String        @unique
  period           String        // e.g. "2026-03"
  amount           Float
  issuedDate       DateTime
  paidAt           DateTime?
  status           InvoiceStatus @default(ISSUED)
  memo             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  billingAccount BillingAccount @relation(fields: [billingAccountId], references: [id], onDelete: Cascade)
}

// ─── SupportTicket ──────────────────────────────────────

model SupportTicket {
  id              String              @id @default(cuid())
  tenantId        String
  ticketNumber    String              @unique
  title           String
  description     String?             @db.Text
  priority        RequestPriority     @default(MEDIUM)
  status          SupportTicketStatus @default(OPEN)
  category        SupportTicketCategory @default(QUESTION)
  requesterName   String
  requesterEmail  String
  assigneeId      String?
  slaDeadlineAt   DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─── PlatformAuditLog ───────────────────────────────────

model PlatformAuditLog {
  id           String              @id @default(cuid())
  tenantId     String?
  operatorName String
  operatorRole String?
  action       PlatformAuditAction
  target       String
  ipAddress    String?
  result       PlatformAuditResult @default(SUCCESS)
  details      Json?

  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
}

// ─── SalaryHistory ──────────────────────────────────────

model SalaryHistory {
  id            String   @id @default(cuid())
  tenantId      String
  employeeId    String
  baseSalary    Float
  effectiveDate DateTime
  reason        String?
  createdBy     String?
  createdAt     DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId, effectiveDate])
}

// ─── Notification ───────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  tenantId   String
  employeeId String
  type       NotificationType @default(SYSTEM)
  title      String
  message    String
  read       Boolean          @default(false)

  createdAt DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ─── InsuranceRateConfig ────────────────────────────────

model InsuranceRateConfig {
  id             String   @id @default(cuid())
  tenantId       String
  year           Int
  pensionRate    Float    @default(0.045)
  healthRate     Float    @default(0.03545)
  ltcRate        Float    @default(0.1281)
  employmentRate Float    @default(0.009)
  injuryRate     Float    @default(0.007)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, year])
}

// ─── InsuranceContribution ──────────────────────────────

model InsuranceContribution {
  id                 String   @id @default(cuid())
  tenantId           String
  employeeId         String
  year               Int
  month              Int
  grossSalary        Float
  pensionEmployee    Float
  pensionEmployer    Float
  healthEmployee     Float
  healthEmployer     Float
  ltcEmployee        Float
  ltcEmployer        Float
  employmentEmployee Float
  employmentEmployer Float
  injuryEmployer     Float
  totalEmployee      Float
  totalEmployer      Float
  status             String   @default("CALCULATED")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, year, month])
}

// ─── WageConfig ──────────────────────────────────────────

model WageConfig {
  id         String   @id @default(cuid())
  tenantId   String
  employeeId String   @unique
  wageType   WageType @default(STANDARD)

  baseSalary          Float
  contractedOTHours   Float @default(0)
  contractedNSHours   Float @default(0)
  contractedHDHours   Float @default(0)
  hourlyRate          Float?
  annualSalary        Float?

  fixedAllowances      Json @default("[]")
  nonTaxableAllowances Json @default("[]")
  mealAllowanceLimit      Float @default(200000)
  transportAllowanceLimit Float @default(200000)

  effectiveDate DateTime
  isActive      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
}

// ─── SeveranceCalculation ────────────────────────────────

model SeveranceCalculation {
  id         String @id @default(cuid())
  tenantId   String
  employeeId String

  startDate        DateTime
  endDate          DateTime
  totalServiceDays Int
  totalServiceYears Float
  avgDailySalary   Float
  last3MonthsTotal Float
  last3MonthsDays  Int
  severanceAmount  Float
  status           SeveranceStatus @default(ESTIMATED)

  calculatedBy String?
  confirmedBy  String?
  confirmedAt  DateTime?
  paidAt       DateTime?
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
}

// ─── EmploymentContract ──────────────────────────────────

model EmploymentContract {
  id             String @id @default(cuid())
  tenantId       String
  employeeId     String
  contractNumber String

  contractType String
  startDate    DateTime
  endDate      DateTime?

  wageType     WageType
  baseSalary   Float
  annualSalary Float?
  hourlyRate   Float?

  workHoursPerWeek Float @default(40)
  workDaysPerWeek  Int   @default(5)
  workStartTime    String @default("09:00")
  workEndTime      String @default("18:00")
  breakMinutes     Int    @default(60)

  contractedOTHours Float?
  contractedNSHours Float?
  contractedHDHours Float?

  allowances   Json    @default("[]")
  benefits     Json    @default("[]")
  specialTerms String? @db.Text

  status ContractStatus @default(DRAFT)

  signedAt          DateTime?
  signedByEmployee  Boolean   @default(false)
  signedByEmployer  Boolean   @default(false)
  signatureData     String?   @db.Text
  documentId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, contractNumber])
  @@index([tenantId, employeeId])
}

// ─── SubsidyProgram ──────────────────────────────────────

model SubsidyProgram {
  id       String @id @default(cuid())
  tenantId String

  name        String
  provider    String
  category    String
  description String? @db.Text

  eligibilityCriteria Json @default("{}")

  monthlyAmount    Float
  maxDurationMonths Int
  totalMaxAmount   Float?

  applicationStart DateTime?
  applicationEnd   DateTime?

  isActive Boolean @default(true)

  externalApiUrl    String?
  externalProgramId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  matches SubsidyMatch[]

  @@unique([tenantId, name])
}

// ─── SubsidyMatch ────────────────────────────────────────

model SubsidyMatch {
  id         String @id @default(cuid())
  tenantId   String
  programId  String
  employeeId String

  status       SubsidyStatus @default(ELIGIBLE)
  matchScore   Float?
  matchDetails Json          @default("{}")

  appliedAt         DateTime?
  applicationNumber String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  rejectedReason    String?

  receivingStartDate DateTime?
  receivingEndDate   DateTime?
  totalReceived      Float     @default(0)
  monthlyAmount      Float     @default(0)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program  SubsidyProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  employee Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, programId, employeeId])
  @@index([tenantId, employeeId])
}
